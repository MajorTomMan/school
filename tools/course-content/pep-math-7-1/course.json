      "aliases": ["第一章 有理数"],
      "sections": [
        {
          "id": "1.1",
          "number": "1.1",
          "title": "正数和负数",
          "pages": [
            {
              "id": "1.1-01",
              "type": "lesson",
              "title": "具有相反意义的量",
              "sourcePage": 2,
              "sourceAnchors": [
                {"page": 2, "text": "零上温度和零下温度是以0℃为分界点的具有相反意义的量"},
                {"page": 2, "text": "0既不是正数，也不是负数"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "零上温度和零下温度是以0 ℃为分界点的具有相反意义的量。"},
                {"type": "textbook_text", "text": "在数学中，像3，50，7.8%这样大于0的数叫作正数，像−3，−10，−0.7%这样在正数前加上符号“−”的数叫作负数，其中符号“−”是负号，读作“负”。"},
                {"type": "textbook_text", "text": "0既不是正数，也不是负数。"},
                {"type": "visualization", "renderer": "opposite_quantities", "params": {}},
                {"type": "conclusion", "text": "正数和负数可以分别表示同一问题中具有相反意义的量。"}
              ]
            },
            {
              "id": "1.1-02",
              "type": "lesson",
              "title": "用正数和负数表示相反意义的量",
              "sourcePage": 3,
              "sourcePageEnd": 4,
              "sourceAnchors": [
                {"page": 3, "text": "如果一个问题中出现具有相反意义的量就可以用正数和负数分别表示它们"},
                {"page": 4, "text": "0是正数与负数的分界"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "如果一个问题中出现具有相反意义的量，就可以用正数和负数分别表示它们。"},
                {
                  "type": "worked_example",
                  "statement": "如果用正数表示超过标准质量的克数，那么比标准质量多65 g用+65 g表示，比标准质量少30 g用−30 g表示。",
                  "steps": [],
                  "result": "符号取决于题目中规定的正方向或正意义。"
                },
                {"type": "conclusion", "text": "先明确基准和正意义，再用正、负数表示相反的变化。"}
              ]
            }
          ]
        },
        {
          "id": "1.2",
          "number": "1.2",
          "title": "有理数及其大小比较",
          "aliases": ["有理数的概念", "有理数概念", "有理数的大小比较", "有理数分类"],
          "pages": [
            {
              "id": "1.2-01",
              "type": "lesson",
              "title": "有理数的概念",
              "sourcePage": 7,
              "sourceAnchors": [
                {"page": 7, "text": "正整数0负整数统称为整数"},
                {"page": 7, "text": "可以写成分数形式的数称为有理数"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "正整数、0、负整数统称为整数。"},
                {"type": "textbook_text", "text": "可以写成分数形式的数称为有理数。"},
                {"type": "formula", "expression": "a/b", "conditions": ["a、b为整数", "b≠0"]},
                {"type": "visualization", "renderer": "rational_classification", "params": {}},
                {"type": "conclusion", "text": "整数、有限小数和无限循环小数都可以写成分数形式，因此都属于有理数。"}
              ]
            },
            {
              "id": "1.2-02",
              "type": "lesson",
              "title": "正有理数和负有理数",
              "sourcePage": 8,
              "sourceAnchors": [
                {"page": 8, "text": "所有正有理数组成正有理数集合所有负有理数组成负有理数集合"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "所有正有理数组成正有理数集合，所有负有理数组成负有理数集合。"},
                {"type": "visualization", "renderer": "rational_classification", "params": {}},
                {"type": "conclusion", "text": "0是有理数，但既不属于正有理数集合，也不属于负有理数集合。"}
              ]
            },
            {
              "id": "1.2-03",
              "type": "lesson",
              "title": "数轴",
              "sourcePage": 8,
              "sourcePageEnd": 10,
              "sourceAnchors": [
                {"page": 8, "text": "下面我们在此基础上直观表示有理数"},
                {"page": 9, "text": "通常规定直线上从原点向右或上为正方向"},
                {"page": 10, "text": "规定了原点正方向和单位长度的直线叫作数轴"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "通常规定直线上从原点向右（或上）为正方向，从原点向左（或下）为负方向。"},
                {"type": "textbook_text", "text": "像这样，规定了原点、正方向和单位长度的直线叫作数轴。"},
                {"type": "visualization", "renderer": "number_line", "params": {"min": -5, "max": 5, "draggable": true}},
                {"type": "conclusion", "text": "原点、正方向和单位长度是数轴的三个要素。"}
              ]
            },
            {
              "id": "1.2-04",
              "type": "lesson",
              "title": "相反数",
              "sourcePage": 11,
              "sourcePageEnd": 12,
              "sourceAnchors": [
                {"page": 11, "text": "数轴上与原点的距离是3的点有两个"},
                {"page": 12, "text": "只有符号不同的两个数互为相反数"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "像3和−3，1/2和−1/2这样只有符号不同的两个数，互为相反数。"},
                {"type": "textbook_text", "text": "0的相反数是0。"},
                {"type": "formula", "expression": "a和−a互为相反数"},
                {"type": "visualization", "renderer": "opposite_numbers", "params": {}}
              ]
            },
            {
              "id": "1.2-05",
              "type": "lesson",
              "title": "绝对值",
              "sourcePage": 13,
              "sourcePageEnd": 14,
              "sourceAnchors": [
                {"page": 13, "text": "一个正数的绝对值是它本身一个负数的绝对值是它的相反数0的绝对值是0"},
                {"page": 14, "text": "数轴上的点离原点越近它所表示的数的绝对值越小"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "一般地，数轴上表示数a的点与原点的距离叫作数a的绝对值。"},
                {"type": "textbook_text", "text": "一个正数的绝对值是它本身；一个负数的绝对值是它的相反数；0的绝对值是0。"},
                {"type": "formula", "expression": "|a|≥0"},
                {"type": "visualization", "renderer": "absolute_value", "params": {}},
                {"type": "conclusion", "text": "绝对值表示数轴上的点到原点的距离。"}
              ]
            },
            {
              "id": "1.2-06",
              "type": "lesson",
              "title": "有理数的大小比较",
              "aliases": ["大小比较"],
              "sourcePage": 14,
              "sourcePageEnd": 15,
              "sourceAnchors": [
                {"page": 14, "text": "有理数的大小比较"},
                {"page": 15, "text": "左边的数小于右边的数"},
                {"page": 15, "text": "两个负数绝对值大的反而小"}
              ],
              "blocks": [
                {"type": "textbook_text", "text": "在水平的数轴上表示有理数，数学中规定：它们从左到右的顺序，就是从小到大的顺序，即左边的数小于右边的数。"},
                {"type": "textbook_text", "text": "正数大于0，0大于负数，正数大于负数；两个负数，绝对值大的反而小。"},
                {"type": "visualization", "renderer": "number_comparison", "params": {}},
                {"type": "conclusion", "text": "比较有理数大小时，可以先判断符号；比较两个负数时，再比较绝对值。"}
              ]
            },
            {
